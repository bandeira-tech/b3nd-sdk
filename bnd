#!/bin/bash

# b3nd-sdk CLI runner — delegates to the published @bandeira-tech/b3nd-cli on JSR.
# Usage: ./bnd <command> [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

deno run --allow-read --allow-write --allow-env --allow-net \
  --config "$SCRIPT_DIR/deno.json" \
  "jsr:@bandeira-tech/b3nd-cli" "$@"
