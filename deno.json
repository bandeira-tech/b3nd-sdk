{
  "name": "@bandeira-tech/b3nd-sdk",
  "version": "0.8.1",
  "description": "Universal persistence SDK with URI-based addressing, encryption, and multi-backend support (PostgreSQL, HTTP, WebSocket, in-memory)",
  "exports": {
    ".": "./src/mod.ts",
    "./auth": "./src/auth.ts",
    "./types": "./src/types.ts",
    "./hash": "./src/hash.ts",
    "./encrypt": "./src/encrypt.ts",
    "./client-console": "./src/client-console.ts",
    "./network": "./src/network.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "canonicalize": "npm:canonicalize@2.0.0",
    "@bandeira-tech/b3nd-stores/postgres": "../b3nd-stores/postgres/mod.ts",
    "@bandeira-tech/b3nd-stores/mongo": "../b3nd-stores/mongo/mod.ts",
    "@bandeira-tech/b3nd-stores/sqlite": "../b3nd-stores/sqlite/mod.ts",
    "@bandeira-tech/b3nd-stores/fs": "../b3nd-stores/fs/mod.ts",
    "@bandeira-tech/b3nd-stores/ipfs": "../b3nd-stores/ipfs/mod.ts",
    "@bandeira-tech/b3nd-stores/s3": "../b3nd-stores/s3/mod.ts",
    "@bandeira-tech/b3nd-stores/elasticsearch": "../b3nd-stores/elasticsearch/mod.ts",
    "@bandeira-tech/b3nd-stores/localstorage": "../b3nd-stores/localstorage/mod.ts",
    "@bandeira-tech/b3nd-stores/indexeddb": "../b3nd-stores/indexeddb/mod.ts"
  },
  "tasks": {
    "check": "deno check src/mod.ts",
    "test": "deno test --allow-all libs/b3nd-*/",
    "publish:jsr": "bash scripts/prepublish.sh && deno publish --allow-dirty; bash scripts/postpublish.sh"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ]
  },
  "publish": {
    "exclude": [
      "!_vendor/",
      "apps/",
      "libs/",
      "tests/",
      "skills/",
      ".github/",
      "scripts/",
      "dist/",
      "build/",
      "node_modules/",
      "build*.ts",
      ".env*",
      "*.test.ts",
      "*.js",
      "*.lock",
      "package.json",
      "package-lock.json",
      "tsup.config.ts",
      "tsconfig.web.json",
      ".npmignore",
      "Makefile",
      "BROWSER_USER_MANUAL.md"
    ]
  },
  "workspace": [
    "libs/b3nd-core",
    "libs/b3nd-hash",
    "libs/b3nd-msg",
    "libs/b3nd-client-memory",
    "libs/b3nd-client-http",
    "libs/b3nd-client-ws",
    "libs/b3nd-client-console",
    "libs/b3nd-network",
    "libs/b3nd-testing",
    "libs/b3nd-auth",
    "libs/b3nd-encrypt",
    "libs/b3nd-listener",
    "libs/b3nd-wallet",
    "libs/b3nd-managed-node",
    "libs/b3nd-rig",
    "apps/b3nd-cli",
    "apps/b3nd-node",
    "apps/sdk-inspector",
    "apps/vault-listener",
    "tests",
    ".claude-plugin/mcp-server"
  ]
}
