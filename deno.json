{
  "name": "@bandeira-tech/b3nd-sdk",
  "version": "0.9.4",
  "description": "Universal persistence SDK with URI-based addressing, encryption, and multi-backend support (PostgreSQL, HTTP, WebSocket, in-memory)",
  "exports": {
    ".": "./src/mod.ts",
    "./core": "./src/core.ts",
    "./canon": "./src/canon.ts",
    "./msg": "./src/msg.ts",
    "./auth": "./src/auth.ts",
    "./types": "./src/types.ts",
    "./hash": "./src/hash.ts",
    "./encrypt": "./src/encrypt.ts",
    "./network": "./src/network.ts",
    "./client-console": "./src/client-console.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@bandeira-tech/b3nd-core": "../b3nd-core/mod.ts",
    "@bandeira-tech/b3nd-core/types": "../b3nd-core/libs/b3nd-core/types.ts",
    "@bandeira-tech/b3nd-core/encoding": "../b3nd-core/libs/b3nd-core/encoding.ts",
    "@bandeira-tech/b3nd-core/binary": "../b3nd-core/libs/b3nd-core/binary.ts",
    "@bandeira-tech/b3nd-core/network": "../b3nd-core/libs/b3nd-network/mod.ts",
    "@bandeira-tech/b3nd-core/client-console": "../b3nd-core/libs/b3nd-client-console/mod.ts",
    "@bandeira-tech/b3nd-canon": "../b3nd-canon/mod.ts",
    "@bandeira-tech/b3nd-canon/msg": "../b3nd-canon/msg.ts",
    "@bandeira-tech/b3nd-canon/hash": "../b3nd-canon/hash.ts",
    "@bandeira-tech/b3nd-canon/auth": "../b3nd-canon/auth.ts",
    "@bandeira-tech/b3nd-canon/encrypt": "../b3nd-canon/encrypt.ts",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "canonicalize": "npm:canonicalize@2.0.0"
  },
  "tasks": {
    "check": "deno check src/mod.ts src/core.ts src/canon.ts src/msg.ts",
    "test": "deno test --allow-all libs/b3nd-*/",
    "publish:jsr": "bash scripts/prepublish.sh && deno publish --allow-dirty; bash scripts/postpublish.sh"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "deno.ns"
    ]
  },
  "publish": {
    "exclude": [
      "!_vendor/",
      "apps/",
      "libs/",
      "tests/",
      "skills/",
      ".github/",
      "scripts/",
      "dist/",
      "build/",
      "node_modules/",
      "build*.ts",
      ".env*",
      "*.test.ts",
      "*.js",
      "*.lock",
      "package.json",
      "package-lock.json",
      "tsup.config.ts",
      "tsconfig.web.json",
      ".npmignore",
      "Makefile",
      "BROWSER_USER_MANUAL.md"
    ]
  },
  "workspace": [
    "libs/b3nd-managed-node",
    "apps/b3nd-cli",
    "apps/b3nd-node",
    "apps/sdk-inspector",
    "tests"
  ]
}
